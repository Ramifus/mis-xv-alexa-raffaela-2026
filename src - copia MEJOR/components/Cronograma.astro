---
// Cronograma.astro  (Itinerario)

const icons: Record<string, string> = {
    church: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v3M10.5 3.5h3"/><path d="M12 5 7 9v11h10V9z"/><path d="M4 20v-9l3-2M20 20v-9l-3-2"/><path d="M10.5 20v-4h3v4"/><path d="M12 11v3M10.5 12.5h3"/></svg>`,
    envelope: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3.5 7l8.5 6 8.5-6"/><path d="M12 13.2c-.8-1-2.4-.5-2.4.6 0 .8 1.3 1.6 2.4 2.2 1.1-.6 2.4-1.4 2.4-2.2 0-1.1-1.6-1.6-2.4-.6z"/></svg>`,
    couple: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="5.5" r="1.8"/><circle cx="15.5" cy="5.5" r="1.8"/><path d="M6.5 20v-6a2 2 0 014 0v6"/><path d="M13.5 20l1-6a2 2 0 013.9 0"/><path d="M10.5 9.5c1 1 3 1 4 0"/></svg>`,
    toast: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3l1 6a2 2 0 11-3.4 0z"/><path d="M7.2 11.5V20M5.5 20h3.4"/><path d="M16 3l-1 6a2 2 0 103.4 0z"/><path d="M16.8 11.5V20M15.1 20h3.4"/></svg>`,
    dinner: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18h11"/><path d="M4.5 18a5 5 0 019.9 0"/><path d="M9.5 13v-2"/><path d="M18 4l-1 5a1.6 1.6 0 003 0z"/><path d="M18 9v9M16.5 18h3"/></svg>`,
    car: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17v-3l2-4h9l3 4v3"/><path d="M3 17h16"/><circle cx="7.5" cy="17.5" r="1.6"/><circle cx="15.5" cy="17.5" r="1.6"/><path d="M14 5.5c-.7-.9-2-.4-2 .5 0 .7 1.1 1.4 2 2 .9-.6 2-1.3 2-2 0-.9-1.3-1.4-2-.5z"/></svg>`,
    party: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4.5l1.1 3.2L15 8.8l-2.9 1.1L11 13l-1.1-3.1L7 8.8l2.9-1.1z"/><path d="M18 13l.7 2 2 .7-2 .7-.7 2-.7-2-2-.7 2-.7z"/><path d="M5 15l.5 1.4L7 17l-1.5.6L5 19l-.5-1.4L3 17l1.5-.6z"/></svg>`,
    gift: `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="9" width="18" height="4" rx="1"/><path d="M5 13v8h14v-8"/><path d="M12 9v12"/><path d="M12 9C10 9 8 8 8 6.2 8 5 9 4.5 10 5c1 .5 2 2 2 4z"/><path d="M12 9c2 0 4-1 4-2.8C16 5 15 4.5 14 5c-1 .5-2 2-2 4z"/></svg>`,
    music: `<svg class="w-11 h-11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V6l10-2v12"/><circle cx="6.5" cy="18" r="2.5"/><circle cx="16.5" cy="16" r="2.5"/></svg>`,
};

const items = [
    { titulo: "Recreación", hora: "18:00 h", img: "recreacion.png", side: "left" },
    { titulo: "Vals", hora: "20:00 h", img: "vals.png", side: "right" },
    { titulo: "Discurso y brindis", hora: "20:30 h", img: "discurso.png", side: "left" },
    { titulo: "Cena", hora: "21:00 h", img: "cena.png", side: "right" },
    { titulo: "Baile sorpresa", hora: "22:00 h", img: "baile.png", side: "left" },
    { titulo: "Comienza la fiesta", hora: "22:30 h", img: "comienzo-fiesta.png", side: "right" },
    { titulo: "Gracias por asistir", hora: "1:00 am", img: "gracias.png", side: "left" },
];
---

<div
    id="crono-contenedor"
    class="relative w-full flex flex-col items-center justify-center text-center px-6 pt-2 pb-14"
>
    <!-- TÍTULO -->
    <h2
        id="crono-titulo"
        class="m-0 font-romantic text-[#ffc065] text-[clamp(2.6rem,12vw,3.4rem)] leading-[1.1]"
    >
        Itinerario
    </h2>

    <!-- TIMELINE -->
    <div id="crono-timeline" class="relative w-full max-w-[380px] mx-auto mt-10">
        <!-- LÍNEA CENTRAL (recta con puntas curvadas a la derecha) -->
        <div
            class="absolute left-1/2 top-5 bottom-5 w-px bg-[#ffc065]/70"
        >
        </div>
        <svg
            class="absolute left-1/2 -top-6 w-11 h-11 text-[#ffc065]/70"
            viewBox="0 0 44 44"
            fill="none"
        >
            <path
                d="M1 44 Q1 1 44 1"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
            ></path>
        </svg>
        <svg
            class="absolute left-1/2 -bottom-6 w-11 h-11 -translate-x-11 text-[#ffc065]/70"
            viewBox="0 0 44 44"
            fill="none"
        >
            <path
                d="M43 0 Q43 43 0 43"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
            ></path>
        </svg>

        <!-- FILAS -->
        <div class="relative z-10 flex flex-col gap-9">
            {
                items.map((it) => (
                    <div class="crono-fila grid grid-cols-2 items-center gap-5">
                        {it.side === "left" ? (
                            <>
                                <div class="flex justify-center">
                                    <div
                                        class="w-11 h-11 bg-[#ffc065]"
                                        style={`-webkit-mask:url('/imagenes/${it.img}') center/contain no-repeat; mask:url('/imagenes/${it.img}') center/contain no-repeat;`}
                                    />
                                </div>
                                <div class="text-center">
                                    <p class="m-0 font-cormorant not-italic text-[#f1e9d6] text-[20px] leading-[1.35]">
                                        {it.titulo}
                                    </p>
                                    <p class="m-0 font-cormorant not-italic text-[#ffc065] text-[20px] leading-[1.35]">
                                        {it.hora}
                                    </p>
                                </div>
                            </>
                        ) : (
                            <>
                                <div class="text-center">
                                    <p class="m-0 font-cormorant not-italic text-[#f1e9d6] text-[20px] leading-[1.35]">
                                        {it.titulo}
                                    </p>
                                    <p class="m-0 font-cormorant not-italic text-[#ffc065] text-[20px] leading-[1.35]">
                                        {it.hora}
                                    </p>
                                </div>
                                <div class="flex justify-center">
                                    <div
                                        class="w-11 h-11 bg-[#ffc065]"
                                        style={`-webkit-mask:url('/imagenes/${it.img}') center/contain no-repeat; mask:url('/imagenes/${it.img}') center/contain no-repeat;`}
                                    />
                                </div>
                            </>
                        )}
                    </div>
                ))
            }
        </div>
    </div>

    <!-- FOOTER: REGALO -->
    <div id="crono-footer" class="mt-12 text-[#ffc065]">
        <span set:html={icons.gift} />
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initCrono() {
        const contenedor = document.getElementById("crono-contenedor");
        if (!contenedor) return;

        gsap.from(
            ["#crono-titulo", ".crono-fila", "#crono-footer"],
            {
                opacity: 0,
                y: 22,
                duration: 1,
                ease: "power3.out",
                stagger: 0.12,
                scrollTrigger: {
                    trigger: contenedor,
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    }

    document.addEventListener("DOMContentLoaded", initCrono);
    document.addEventListener("astro:page-load", initCrono);
</script>
