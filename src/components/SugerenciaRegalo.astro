---
// SugerenciaRegalo.astro  (Sugerencia de Regalos)
---

<div
    id="sug-contenedor"
    class="relative w-full flex flex-col items-center justify-center text-center px-6 pt-24 pb-14"
>
    <!-- WRAPPER (permite que las flores sobresalgan del card) -->
    <div class="relative w-full max-w-[350px] mx-auto">
    <!-- CARD -->
    <div
        id="sug-card"
        class="relative w-full rounded-[26px] overflow-hidden
               border border-[#ffc065]/40 shadow-[0_18px_45px_rgba(0,0,0,0.45)]"
    >
        <!-- FONDO AZUL -->
        <img
            src="/imagenes/azul.png"
            alt=""
            class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none select-none"
        />

        <!-- CONTENIDO -->
        <div class="relative z-10 flex flex-col items-center px-8 pt-24 pb-16">
            <!-- TÍTULO -->
            <h2
                class="m-0 font-romantic text-[#ffc065] text-[clamp(2.4rem,11vw,3.2rem)] leading-[1.1]"
            >
                Sugerencia de Regalos
            </h2>

            <!-- TEXTO -->
            <p
                class="m-0 mt-5 font-cormorant not-italic text-[#f1e9d6] text-[17px] leading-[1.7] max-w-[290px]"
            >
                Tu presencia será nuestro regalo más grande, pero si deseas
                obsequiarme algo puede ser por QR o lluvia de sobres (no te
                preocupes por traer el tuyo, en recepción habrá suficientes para
                todos).
            </p>

            <!-- QR -->
            <div class="mt-7 bg-white rounded-2xl p-4 shadow-lg">
                <img
                    src="/imagenes/qr.png"
                    alt="Código QR"
                    class="w-[210px] h-[210px] object-contain"
                />
            </div>
        </div>
    </div>

    <!-- FLOR ESQUINA SUPERIOR DERECHA -->
    <div
        id="sug-flor-tr"
        class="pointer-events-none absolute -top-5 -right-5 w-[42%] max-w-[150px] z-20"
    >
        <img
            src="/imagenes/florcostado.png"
            alt=""
            class="select-none w-full h-auto scale-x-[-1]"
        />
    </div>

    <!-- FLOR ESQUINA INFERIOR IZQUIERDA -->
    <div
        id="sug-flor-bl"
        class="pointer-events-none absolute -bottom-5 -left-5 w-[42%] max-w-[150px] z-20"
    >
        <img
            src="/imagenes/florcostado.png"
            alt=""
            class="select-none w-full h-auto scale-y-[-1]"
        />
    </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initSug() {
        const contenedor = document.getElementById("sug-contenedor");
        if (!contenedor) return;

        gsap.from("#sug-card", {
            scale: 0.9,
            opacity: 0,
            duration: 1.1,
            ease: "back.out(1.6)",
            scrollTrigger: {
                trigger: contenedor,
                start: "top 85%",
                toggleActions: "play none none reset",
            },
        });

        // Flor superior derecha: aparece suave desde la derecha
        gsap.fromTo(
            "#sug-flor-tr",
            { opacity: 0, x: 32, scale: 0.94 },
            {
                opacity: 1,
                x: 0,
                scale: 1,
                duration: 1.8,
                delay: 0.4,
                ease: "sine.out",
                scrollTrigger: {
                    trigger: contenedor,
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // Flor inferior izquierda: aparece suave desde la izquierda
        gsap.fromTo(
            "#sug-flor-bl",
            { opacity: 0, x: -32, scale: 0.94 },
            {
                opacity: 1,
                x: 0,
                scale: 1,
                duration: 1.8,
                delay: 0.65,
                ease: "sine.out",
                scrollTrigger: {
                    trigger: contenedor,
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    }

    document.addEventListener("DOMContentLoaded", initSug);
    document.addEventListener("astro:page-load", initSug);
</script>
