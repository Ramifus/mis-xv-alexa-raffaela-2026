---
// src/layouts/Layout.astro
import "../styles/global.css";
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="m-0 p-0">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <link rel="icon" type="image/png" href="/imagenes/corona.png" />
    <link rel="shortcut icon" type="image/png" href="/imagenes/corona.png" />
    <link rel="apple-touch-icon" href="/imagenes/corona.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Crimson+Text:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Crimson+Text:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Charm:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* FORZAR MODO CLARO - DESHABILITAR MODO OSCURO */
      :root {
        color-scheme: light only;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        color-scheme: light only;
      }

      html {
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        color-scheme: light only;
        background-color: transparent;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        overflow-x: hidden;
        background-color: transparent;
        color-scheme: light only;
        position: relative;
      }

      /* Titileo de estrellas */
      @keyframes brillo {
        0%, 100% { opacity: 0.15; transform: scale(0.85); }
        50%      { opacity: 1;    transform: scale(1.15); }
      }

      /* Textura de fondo con opacidad */
      @keyframes fondoZoom {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.1); }
      }

      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("/imagenes/fondoverde.png");
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
        opacity: 1;
        z-index: -1;
        pointer-events: none;
      }

      main {
        background: transparent !important;
      }

      /* ANTI-PARPADEO (FOUC): ocultar el contenido hasta que GSAP prepare
         las animaciones de entrada; luego se revela suavemente. Así ningún
         componente aparece un instante antes de ser ocultado por gsap.from(). */
      main {
        opacity: 0;
      }
      html.contenido-listo main {
        opacity: 1;
        transition: opacity 0.35s ease;
      }

      /* Prevenir cualquier cambio de color por modo oscuro */
      @media (prefers-color-scheme: dark) {
        :root {
          color-scheme: light only !important;
        }

        html,
        body {
          background-color: transparent !important;
          color: inherit !important;
        }

        * {
          color-scheme: light only !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen m-0 p-0">
    <!-- ESTRELLAS / BRILLOS (sobre fondoverde, detrás del contenido) -->
    <div id="estrellas" style="position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;"></div>

    <main class="m-0 p-0 overflow-x-hidden" style="position:relative;z-index:1;">
      <slot />
    </main>

    <!-- REVELAR CONTENIDO (anti-parpadeo): se activa en el frame siguiente a
         que corran los setups de animación, por lo que gsap.from() ya ocultó
         los elementos y no se ve el flash inicial. -->
    <script is:inline>
      (function () {
        function revelar() {
          requestAnimationFrame(function () {
            document.documentElement.classList.add("contenido-listo");
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", revelar);
        } else {
          revelar();
        }
        // Fallback de seguridad por si algo falla.
        setTimeout(function () {
          document.documentElement.classList.add("contenido-listo");
        }, 1500);
      })();
    </script>

    <!-- GENERADOR DE ESTRELLAS -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const cont = document.getElementById("estrellas");
        if (!cont) return;
        const TOTAL = 60;
        for (let i = 0; i < TOTAL; i++) {
          const s = document.createElement("span");
          const size = Math.random() * 2.5 + 1; // 1–3.5px
          s.style.cssText =
            "position:absolute;border-radius:9999px;background:#ffffff;" +
            "left:" + Math.random() * 100 + "%;" +
            "top:" + Math.random() * 100 + "%;" +
            "width:" + size + "px;height:" + size + "px;" +
            "opacity:" + (Math.random() * 0.5 + 0.2) + ";" +
            "box-shadow:0 0 " + (size * 2.5) + "px rgba(255,255,255,0.8);" +
            "animation:brillo " + (Math.random() * 2.5 + 1.8) + "s ease-in-out " +
            (Math.random() * 3) + "s infinite;";
          cont.appendChild(s);
        }
      });
    </script>

    <!-- ANIMACIONES DE ENTRADA GLOBALES -->
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      gsap.registerPlugin(ScrollTrigger);

      // Todos los triggers recalculan posiciones cuando se llama refresh()
      ScrollTrigger.defaults({ invalidateOnRefresh: true });

      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll("[data-entrada]").forEach((el) => {
          gsap.set(el, { opacity: 0, y: 50, scale: 0.97 });

          ScrollTrigger.create({
            trigger: el,
            start: "top 98%",
            onEnter: () => {
              gsap.to(el, {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 1,
                ease: "power3.out",
              });
            },
            onLeaveBack: () => {
              gsap.set(el, { opacity: 0, y: 50, scale: 0.97 });
            },
          });
        });
      });

      // Recalcula todas las posiciones cuando las imágenes ya cargaron.
      // En móvil DOMContentLoaded dispara antes de cargar imágenes,
      // dejando los trigger positions incorrectos.
      window.addEventListener("load", () => {
        setTimeout(() => ScrollTrigger.refresh(), 200);
      });
    </script>
  </body>
</html>
